<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zadanie20_2.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25"
            x:Name="MainStack">
            
            
            <Image
                Source="dotnet_bot.png"
                HeightRequest="200"
                Aspect="AspectFit"
             />

            <Image>
                <Image.Source>
                    <UriImageSource 
                    Uri="https://aka.ms/campus.jpg" 
                    CacheValidity="7:00:00:00"
                    
                    />
                </Image.Source>
                
            </Image>
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
